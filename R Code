dev.off()

# 4. GARCH conditional volatility
png("04_garch_volatility.png", width = 1000, height = 500)
garch_sigma <- sigma(garch_fit) * sqrt(252) * 100
plot(as.numeric(garch_sigma),
     type = "l",
     col  = "#185FA5",
     lwd  = 1.2,
     main = "GARCH(1,1) Conditional Volatility (Annualised)",
     xlab = "Trading Days",
     ylab = "Volatility (%)")
abline(h = ann_vol, col = "red", lty = 2, lwd = 1.5)
legend("topright",
       legend = c("GARCH Vol", "Static Vol"),
       col    = c("#185FA5", "red"),
       lwd = c(1.2, 1.5),
       lty = c(1, 2),
       bty = "n")
dev.off()

# 5. Portfolio vs Benchmark cumulative returns
if (BENCHMARK %in% colnames(returns_all) && exists("combined_pb")) {
  png("05_benchmark_comparison.png", width = 1000, height = 500)
  plot_data <- combined_pb
  colnames(plot_data) <- c("Portfolio", "MSCI World")
  charts.PerformanceSummary(
    plot_data,
    main       = "Portfolio vs MSCI World (URTH)",
    colorset   = c("#185FA5", "#E87722"),
    legend.loc = "topleft"
  )
  dev.off()
}

