# 3. Monte Carlo distribution with VaR lines
png("03_monte_carlo_var.png", width = 900, height = 500)
hist(sim, breaks = 60,
     main = "Monte Carlo Return Distribution (10,000 simulations)",
     xlab = "Simulated 1-Day Return",
